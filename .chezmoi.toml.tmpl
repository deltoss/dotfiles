[interpreters.nu]
  command = "nu"
  args = ["--stdin"]

[cd]
  command = "nu"

{{ $osid := .chezmoi.os -}}
{{- if hasKey .chezmoi.osRelease "id" -}}
{{-   $osid = printf "%s-%s" .chezmoi.os .chezmoi.osRelease.id -}}
{{- end -}}

{{ $email := promptStringOnce . "email" "What is your email address (for git). Match this to your GitHub account's email(s) or your activity graph may not detect the commit." -}}
{{ $username := promptStringOnce . "username" "What is your username (for git)" -}}
{{ $steamUsername := promptStringOnce . "steamUsername" "What is your username (for Steam)" -}}
{{ $computerPurposeChoices := list "personal" "work" -}}
{{ $computerPurpose := promptChoiceOnce . "computerPurpose" "What type of computer are you on" $computerPurposeChoices -}}
[data]
  osid = {{ $osid | quote }}
  email = {{ $email | quote }}
  username = {{ $username | quote }}
  steamUsername = {{ $steamUsername | quote }}
  computerPurpose = {{ $computerPurpose | quote }}
  {{ if eq $computerPurpose "personal" -}}
  vultr_key = {{ onepasswordRead "op://Personal/Vultr/API Key" | quote }}
  {{- end }}
  aider_anthropic_key = {{ onepasswordRead "op://Personal/Claude AI - Personal/AIDER/API Key" | quote }}
  aichat_anthropic_key = {{ onepasswordRead "op://Personal/Claude AI - Personal/AICHAT/API Key" | quote }}
  aichat_openai_key = {{ onepasswordRead "op://Personal/OpenAI - Personal/AICHAT/API Key" | quote }}
  {{ if eq $computerPurpose "personal" -}}
  codecompanion_anthropic_key = {{ onepasswordRead "op://Personal/Claude AI - Personal/CODECOMPANION.NVIM/API Key" | quote }}
  opencode_anthropic_key = {{ onepasswordRead "op://Personal/Claude AI - Personal/OPENCODE/API Key" | quote }}
  fabric_anthropic_key = {{ onepasswordRead "op://Personal/Claude AI - Personal/FABRIC/API Key" | quote }}
  {{- else if eq .computerPurpose "work" -}}
  codecompanion_anthropic_key = {{ onepasswordRead "op://Work/Claude AI - Work/CODECOMPANION.NVIM/API Key" | quote }}
  opencode_anthropic_key = {{ onepasswordRead "op://Work/Claude AI - Work/OPENCODE/API Key" | quote }}
  fabric_anthropic_key = {{ onepasswordRead "op://Work/Claude AI - Work/FABRIC/API Key" | quote }}
  {{- end }}
  {{ if eq $computerPurpose "personal" -}}
  codex_openai_key = {{ onepasswordRead "op://Personal/OpenAI - Personal/CODEX/API Key" | quote }}
  codecompanion_openai_key = {{ onepasswordRead "op://Personal/OpenAI - Personal/CODECOMPANION.NVIM/API Key" | quote }}
  opencode_openai_key = {{ onepasswordRead "op://Personal/OpenAI - Personal/OPENCODE/API Key" | quote }}
  {{- else if eq .computerPurpose "work" -}}
  codecompanion_openai_key = {{ onepasswordRead "op://Work/OpenAI - Work/CODECOMPANION.NVIM/API Key" | quote }}
  opencode_openai_key = {{ onepasswordRead "op://Work/OpenAI - Work/OPENCODE/API Key" | quote }}
  {{- end }}
  {{ if eq $computerPurpose "personal" -}}
  ssh_connections = {{- onepasswordRead "op://Personal/SSH Connections/notesPlain" | quote -}}
  {{- else if eq .computerPurpose "work" -}}
  ssh_connections = {{- onepasswordRead "op://Work/SSH Connections/notesPlain" | quote -}}
  {{- end }}
  {{ if eq .computerPurpose "personal" -}}
  harlequin_configs = {{- onepasswordRead "op://Personal/Harlequin/Configs" | quote -}}
  {{ else if eq .computerPurpose "work" -}}
  harlequin_configs = {{- onepasswordRead "op://Work/Harlequin/Configs" | quote -}}
  {{- end }}
  {{ if eq $computerPurpose "personal" -}}
  mobile_ssh_public_key = {{ onepasswordRead "op://Personal/Mobile Devices SSH Key/public key" | quote }}
  iot_hostname = {{ onepasswordRead "op://Personal/Hostnames/iot" | quote }}
  copyparty_website = {{ onepasswordRead "op://Personal/Copyparty/website" | quote }}
  copyparty_username = {{ onepasswordRead "op://Personal/Copyparty/username" | quote }}
  copyparty_password = {{ onepasswordRead "op://Personal/Copyparty/password" | quote }}
  rclone_personal_gdrive_client_id = {{ onepasswordRead "op://Personal/RClone - Personal Google Drive/Client ID" | quote }}
  rclone_personal_gdrive_client_secret = {{ onepasswordRead "op://Personal/RClone - Personal Google Drive/Client Secret" | quote }}
  {{- end }}
  rclone_notes_gdrive_client_id = {{ onepasswordRead "op://Personal/RClone - Notes Google Drive/Client ID" | quote }}
  rclone_notes_gdrive_client_secret = {{ onepasswordRead "op://Personal/RClone - Notes Google Drive/Client Secret" | quote }}

[diff]
  pager = "delta"

[merge]
  command = "nvim"
  args = [
    "-d",
    {{ printf "%q" "{{ .Destination }}" }},
    {{ printf "%q" "{{ .Source }}" }},
    # Commented below as changing this panel won't actually merge in the edits made to it
    # {{ printf "%q" "{{ .Target }}" }},
  ]