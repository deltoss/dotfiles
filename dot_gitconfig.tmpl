[user]
	name = {{ .username | quote }}
	email = {{ .email | quote }}
[core]
  compression = 9
  whitespace = error
	autocrlf = true
	sshCommand = C:/Windows/System32/OpenSSH/ssh.exe
	editor = nvim
	pager = delta
	hooksPath = ~/.config/git/hooks
[status]
  branch = true
  showStash = true
  showUntractedFiles = all
[log]
  graphColors = blue,yellow,cyan,magenta,green,red
[color "decorate"]
  HEAD = red
  branch = blue
  tag = yellow
  remoteBranch = 166 bold # Dark orange
[color "branch"]
  current = red bold
  local = blue
  remote = 166 # Dark orange
  upstream = green
  plain = default
[diff]
  context = 3
  renames = copies
  interHunkContext = 10
[interactive]
  diffFilter = delta --color-only
  singleKey = true
[delta]
	navigate = true # n/N to jump between diff sections
	light = true
	side-by-side = true
  line-numbers = true
[merge]
	renormalize = true
	ff = false # Even create extra merge commit when fast forward merge would be possible
[mergetool]
	prompt = false
	keepBackup = false
[mergetool "nvimdiff"]
  layout = "LOCAL,BASE,REMOTE / MERGED"
[mergetool "codediff"]
	cmd = nvim \"$MERGED\" -c \"CodeDiff merge \\\"$MERGED\\\"\"
[pull]
	rebase = true
	ff = only # Disallows non ff merges on pull. Overrides merge.ff when pulling
[push]
	autoSetupRemote = true
  default = current
  followTags = true
[rebase]
  autoStash = true # For any unstaged local changes, auto stashes it, then apply it after
  missingCommitsCheck = warn # Warns if you accidentally removed commits whilst editing