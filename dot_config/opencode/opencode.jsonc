{
  "$schema": "https://opencode.ai/config.json",
  "keybinds": {
    // See https://opencode.ai/docs/keybinds/
    "app_exit": "<leader>q,ctrl+q",
    "messages_half_page_up": "ctrl+u",
    "messages_half_page_down": "ctrl+d,ctrl+e",
    "editor_open": "<leader>e,ctrl+o",
  },
  "mcp": {
    "serena": {
      "type": "local",
      "enabled": true,
      "command": [
        "serena",
        "start-mcp-server",
        "--context",
        "ide",
        "--project-from-cwd",
        "--enable-web-dashboard=false"
      ]
    },
    "atlassian": {
      "type": "remote",
      "enabled": true,
      "url": "https://mcp.atlassian.com/v1/sse"
    }
  },
  "agent": {
    "build": {
      "permission": {
        "task": {
          "explore": "deny" // Don't use built-in explore agent, as it won't be able to use serena mcp
        }
      }
    },
    "plan": {
      "permission": {
        "task": {
          "explore": "deny" // Don't use built-in explore agent, as it won't be able to use serena mcp
        }
      }
    }
  }
}