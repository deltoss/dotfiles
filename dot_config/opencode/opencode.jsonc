{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "serena": {
      "type": "local",
      "enabled": true,
      "command": [
        "serena",
        "start-mcp-server",
        "--context",
        "ide",
        "--project-from-cwd",
        "--enable-web-dashboard=false"
      ],
      "timeout": 60000
    },
    "atlassian": {
      "type": "remote",
      "enabled": true,
      "url": "https://mcp.atlassian.com/v1/mcp"
    },
    "todoist": {
      "type": "remote",
      "enabled": true,
      "url": "https://ai.todoist.net/mcp"
    }
  },
  "agent": {
    "explore": {
      "disable": true // Don't use built-in explore agent, as it won't be able to use serena mcp
    }
  }
}