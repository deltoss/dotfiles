layout {
    pane size=1 borderless=true {
        plugin location="tab-bar"
    }
    pane {
        command "nu"
        args "--no-config-file" "--no-std-lib" "~/.config/nushell/custom-commands/quick-launch.nu"
        close_on_exit true
    }
    pane size=1 borderless=true {
        plugin location="status-bar"
    }
}
